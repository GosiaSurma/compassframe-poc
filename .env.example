# ── App ──────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# ── Database ──────────────────────────────────────────────────────────
# PostgreSQL (Neon). Schema=poc keeps this app isolated from other projects in the same DB.
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=verify-full&channel_binding=require&schema=poc"

# ── Email (Resend — https://resend.com) ───────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@yourdomain.com

# ── Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
