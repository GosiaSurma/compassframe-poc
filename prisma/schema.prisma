generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── NextAuth required models ──────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  // "parent" | "teen" — null until onboarding complete
  role          String?
  // "off" | "light" | "full"
  magicalMode   String    @default("off")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  emailVerifyTokens   EmailVerifyToken[]
  parentRelationships Relationship[]       @relation("ParentRelationships")
  teenRelationships   Relationship[]       @relation("TeenRelationships")
  sentInvites         Invite[]             @relation("SentInvites")
  reflectionSessions  ReflectionSession[]
  sentGifts           Gift[]               @relation("SentGifts")
  receivedGifts       Gift[]               @relation("ReceivedGifts")
  challenges          Challenge[]
}

model EmailVerifyToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Relationship {
  id        String   @id @default(cuid())
  parentId  String
  teenId    String
  // "pending" | "active"
  status    String   @default("pending")
  createdAt DateTime @default(now())

  parent User @relation("ParentRelationships", fields: [parentId], references: [id])
  teen   User @relation("TeenRelationships",  fields: [teenId],   references: [id])

  @@unique([parentId, teenId])
}

model Invite {
  id         String   @id @default(cuid())
  fromUserId String
  toEmail    String
  token      String   @unique
  expiresAt  DateTime
  // "pending" | "accepted" | "expired"
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  fromUser User @relation("SentInvites", fields: [fromUserId], references: [id])
}

model ReflectionSession {
  id          String   @id @default(cuid())
  userId      String
  topic       String
  // "active" | "completed"
  status      String   @default("active")
  roundCount  Int      @default(0)
  imageUrl    String?
  imagePrompt String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages   Message[]
  summaries  ReflectionSummary[]
  gifts      Gift[]
  challenges Challenge[]
}

model Message {
  id              String   @id @default(cuid())
  sessionId       String
  // "user" | "assistant"
  role            String
  content         String
  // Present on assistant messages that carry an insight
  insightText     String?
  // "resonates" | "not_quite" | "clarify" — set when user responds
  insightResponse String?
  // Single approved emotion word named by the assistant in this turn
  emotionLabel          String?
  // Structured MI response fields
  followUpQuestion      String?
  progressStage         String?
  summaryReadinessScore Int?
  symbolicMarker        String?
  createdAt             DateTime @default(now())

  session ReflectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ReflectionSummary {
  id        String   @id @default(cuid())
  sessionId String
  text      String
  selected  Boolean  @default(false)
  edited    Boolean  @default(false)
  createdAt DateTime @default(now())

  session ReflectionSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Gift {
  id         String    @id @default(cuid())
  fromUserId String
  toUserId   String
  sessionId  String?
  // Optional framing line written by the sender
  title      String?
  message    String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  fromUser User               @relation("SentGifts",     fields: [fromUserId], references: [id])
  toUser   User               @relation("ReceivedGifts", fields: [toUserId],   references: [id])
  session  ReflectionSession? @relation(fields: [sessionId], references: [id])
}

model Challenge {
  id          String    @id @default(cuid())
  userId      String
  sessionId   String?
  text        String
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  session ReflectionSession? @relation(fields: [sessionId], references: [id])
}
